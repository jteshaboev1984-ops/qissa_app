# Local generation remains the default and needs no backend.
VITE_QISSA_STORY_PROVIDER=local

# Set provider=remote and point these to the deployed Supabase Edge Functions.
VITE_QISSA_STORY_ENDPOINT=
VITE_QISSA_STATE_ENDPOINT=
VITE_QISSA_SUPABASE_PUBLISHABLE_KEY=
VITE_QISSA_STORY_TIMEOUT_MS=45000
VITE_QISSA_STORY_FALLBACK_TO_LOCAL=true

# Server-only Supabase Edge Function secrets (never prefix these with VITE_):
# OPENAI_API_KEY=...
# QISSA_AI_ENABLED=false
# OPENAI_STORY_MODEL=gpt-5.5
# OPENAI_SAFETY_MODEL=gpt-5.5
