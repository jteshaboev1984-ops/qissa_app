{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["ES2022", "DOM"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "supabase/functions/audio-request/*.ts",
    "supabase/functions/audio-request/*.d.ts",
    "supabase/functions/audio-cleanup/*.ts"
  ]
}
