{
  "name": "qissa-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:story-ai": "tsc --project tsconfig.story-ai.json",
    "typecheck:audio-agent": "tsc --project tsconfig.audio-agent.json",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:story-copy": "node scripts/check-story-copy.mjs",
    "check:story-core": "node scripts/check-story-core-proof.mjs",
    "check:space-copy": "node scripts/check-space-copy.mjs",
    "check:localized-fallback": "node scripts/check-localized-fallback.mjs",
    "preview:stories": "node scripts/preview-stories.mjs",
    "check:story-service": "node scripts/check-story-service-boundary.mjs",
    "check:story-ai": "node scripts/check-story-ai-safety.mjs",
    "check:backend-contracts": "node scripts/check-backend-contracts.mjs",
    "check:privacy": "node scripts/check-privacy-contract.mjs",
    "check:listening": "node scripts/check-listening-contract.mjs",
    "check:audio-agent": "node scripts/check-audio-agent-contract.mjs",
    "smoke:story-live": "node scripts/smoke-story-generate-live.mjs",
    "smoke:privacy-live": "node scripts/smoke-privacy-live.mjs",
    "smoke:audio-live": "node scripts/smoke-audio-live.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "check:bedtime-session": "node scripts/check-bedtime-session-polish.mjs",
    "check:cosmos-bedtime": "node scripts/check-cosmos-bedtime.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.7",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
