{
  "name": "qissa-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:story-ai": "tsc --project tsconfig.story-ai.json",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:story-copy": "node scripts/check-story-copy.mjs",
    "preview:stories": "node scripts/preview-stories.mjs",
    "check:story-service": "node scripts/check-story-service-boundary.mjs",
    "check:story-ai": "node scripts/check-story-ai-safety.mjs",
    "check:backend-contracts": "node scripts/check-backend-contracts.mjs",
    "smoke:story-live": "node scripts/smoke-story-generate-live.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.7",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
